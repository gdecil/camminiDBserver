{
  "name": "cammini",
  "version": "1.0.0",
  "description": "App per visualizzare tracce GPX e pianificare itinerari escursionistici",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.cjs",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "electron": "electron .",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "exif-js": "^2.3.0",
    "exif-reader": "^2.0.3",
    "express": "^4.18.2",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.20.0",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.8"
  },
  "build": {
    "appId": "com.cammini.app",
    "productName": "Cammini",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "electron/icon.ico"
    },
    "portable": {
      "artifactName": "Cammini-${version}.exe"
    }
  }
}
