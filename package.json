{
  "name": "cammini-db-server",
  "version": "1.0.0",
  "description": "App per visualizzare tracce GPX e pianificare itinerari escursionistici",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.cjs",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "db:migrate-sqlite": "node server/migrate-sqlite-to-postgres.cjs",
    "db:dump": "node server/db-dump.cjs",
    "db:restore": "node server/db-restore.cjs",
    "db:migrate-target": "node server/db-migrate-target.cjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "dotenv": "^17.4.1",
    "exif-js": "^2.3.0",
    "express": "^4.18.2",
    "leaflet": "^1.9.4",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.20.0",
    "react-window": "^1.8.10",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "vite": "^7.0.0"
  }
}
